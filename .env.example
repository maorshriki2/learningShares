# Copy to .env next to learningSharesDesktop.exe and fill in your keys.

ANTHROPIC_API_KEY=
SEC_USER_AGENT=YourApp/1.0 (you@example.com)

REDIS_URL=

POLYGON_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=

## Social (optional)
# Comma-separated base URLs of your self-hosted Nitter-compatible instances.
# Example (local Docker): NITTER_INSTANCES=http://127.0.0.1:8080
NITTER_INSTANCES=

API_HOST=127.0.0.1
API_PORT=8000
# Origin only (no /api/v1). The Streamlit client builds paths like /api/v1/...
API_PUBLIC_URL=http://127.0.0.1:8000

STREAMLIT_SERVER_PORT=8501

TRANSFORMERS_CACHE=
